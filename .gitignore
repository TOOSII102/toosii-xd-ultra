# Session files — ephemeral on Heroku, regenerated via SESSION_ID
bot/session/
# but keep creds.json if you want to pre-seed a session
!bot/session/creds.json

# Node
node_modules/
bot/node_modules/
npm-debug.log
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
bot/tmp/

# Replit-specific
.replit
replit.nix
.breakpoints

# yt-dlp binary — auto-downloaded on startup, no need to commit
bot/yt-dlp

# Runtime data files — generated by the bot at runtime, instance-specific
# These are NOT ignored so the clean defaults ship with the repo,
# but you should avoid committing changes made while the bot is running.
# bot/data/config.json     ← kept for clean defaults only
bot/data/warnings.json
bot/data/status_detection_logs.json
bot/data/autoViewConfig.json
bot/data/autoReactConfig.json
bot/data/member_detection.json
bot/data/welcome_data.json
bot/data/viewonce_messages/
bot/data/antiviewonce/
