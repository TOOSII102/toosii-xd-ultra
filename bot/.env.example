# ═══════════════════════════════════════════════════════════════
  #   TOOSII-XD ULTRA — Bot Configuration
  #   Copy this file to .env and fill in your details
  #   cp .env.example .env
  # ═══════════════════════════════════════════════════════════════

  # ── REQUIRED ────────────────────────────────────────────────────

  # Session ID — get yours FREE at:
  # https://toosiitechdevelopertools.zone.id/session
  SESSION_ID=

  # Your WhatsApp number (country code + number, no + or spaces)
  # Example: 254712345678  or  447911123456  or  12025551234
  OWNER_NUMBER=

  # ── BOT SETTINGS ────────────────────────────────────────────────

  # Command prefix (default: comma)
  PREFIX=,

  # Bot display name
  BOT_NAME=TOOSII-XD ULTRA

  # Your name shown in menus and footer
  OWNER_NAME=YourName

  # public  = everyone can use the bot
  # private = only owner and sudo users
  MODE=public

  # Timezone (affects ,time and ,worldclock commands)
  # List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
  TIME_ZONE=Africa/Nairobi

  # ── PLATFORM ────────────────────────────────────────────────────

  # Port for the health-check web server
  # Leave blank on Heroku / Koyeb / Render — they set it automatically
  # Only set manually if running on a VPS or Pterodactyl
  PORT=3000

  # WhatsApp Channel JID — makes menu appear as "Forwarded from <channel>"
  # How to get: open your WhatsApp Channel → copy invite link → extract ID
  # Format: 120363XXXXXXXXXX@newsletter  (leave blank to disable)
  NEWSLETTER_JID=

  # ── API KEYS (all optional — free fallbacks exist) ──────────────

  # OpenAI — for ,gpt and AI chatbot commands (free fallback: Pollinations AI)
  # Get key: https://platform.openai.com/api-keys
  OPENAI_API_KEY=

  # Google Gemini — for ,gemini command
  # Get key: https://aistudio.google.com/app/apikey
  GEMINI_API_KEY=

  # OpenWeatherMap — for ,weather command (free fallback available)
  # Get key FREE: https://openweathermap.org/api
  WEATHER_API_KEY=

  # NewsAPI — for ,news command (free fallback: BBC RSS)
  # Get key FREE: https://newsapi.org/register
  NEWSAPI_API_KEY=

  # RapidAPI — for various search and download commands
  # Get key FREE: https://rapidapi.com
  RAPIDAPI_API_KEY=
  